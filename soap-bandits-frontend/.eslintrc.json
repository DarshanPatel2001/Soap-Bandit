{
  "extends": [
    "react-app",
    "eslint:recommended",
    "plugin:react/recommended",
    "prettier"
  ],
  "plugins": ["react", "prettier"],
 "rules": {
  "prettier/prettier": "error",
  "react/react-in-jsx-scope": "off",
  "react/jsx-uses-react": "off"
},
  "settings": {
    "react": {
      "version": "detect"
    }
  }
}